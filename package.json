{
  "name": "garitacenter",
  "description": "Reporte de Garitas",
  "version": "0.0.1",
  "scripts": {
    "dev": "sapper dev",
    "build": "sapper build --legacy",
    "export": "sapper export --legacy",
    "start": "node __sapper__/build",
    "cy:run": "cypress run",
    "cy:open": "cypress open",
    "test": "run-p --race dev cy:run",
    "version": "git rev-parse HEAD > static/version",
    "google:clean": "gsutil -m rm -r gs://www.garitacenter.com/*",
    "google:upload": "gsutil -m cp -r ./__sapper__/export/* gs://www.garitacenter.com",
    "deploy": "npm run version && npm run google:clean && npm run google:upload"
  },
  "dependencies": {
    "compression": "^1.7.1",
    "d3": "^5.15.0",
    "polka": "next",
    "sirv": "^0.4.0",
    "twitter": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.0.0",
    "@babel/plugin-syntax-dynamic-import": "^7.0.0",
    "@babel/plugin-transform-runtime": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/runtime": "^7.0.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^1.12.0",
    "rollup-plugin-babel": "^4.0.2",
    "rollup-plugin-commonjs": "^10.0.0",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-replace": "^2.0.0",
    "rollup-plugin-svelte": "^5.0.1",
    "rollup-plugin-terser": "^5.1.3",
    "sapper": "^0.27.0",
    "svelte": "^3.0.0",
    "svelte-preprocess": "^3.2.6"
  }
}
